#!/usr/bin/env bash
# Control YouTube Music Desktop via its local API server.
# Download: https://github.com/pear-devs/pear-desktop/releases
# Usage: ytm <command>
#   like    | l    thumbs up the current song
#   dislike | d    thumbs down the current song, then skip to next
#   next  | n    skip to next song
#   prev  | p    go to previous song
#   pause        pause playback
#   play         resume playback
#   info  | i    print current song title / artist / album

set -u
api="http://127.0.0.1:26538/api/v1"
post() { curl -fsS -X POST "$api/$1" >/dev/null; }

case "${1:-}" in
  like|l)    post "like" ;;
  dislike|d) post "dislike" && post "next" ;;
  next|n)    post "next" ;;
  prev|p)    post "previous" ;;
  pause)     post "pause" ;;
  play)      post "play" ;;
  info|i)
    curl -fsS "$api/song" \
      | jq -r '
          def fmt: (./60|floor|tostring) + ":" + (./60|(.-floor)*60|floor|tostring|if length==1 then "0"+. else . end);
          "\(.title)\n  \(.artist)\n  \(.album)\n  \(.songDuration|fmt)"
        '
    ;;
  "")
    echo "usage: ytm <like|dislike|next|prev|pause|play|info>" >&2
    exit 1
    ;;
  *)
    echo "ytm: unknown command: $1" >&2
    exit 1
    ;;
esac
