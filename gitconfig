[color]
	diff = auto
	status = auto
	branch = auto
[core]
	editor = vim
	autocrlf = input
	pager = less -+$LESS -RSF
	excludesFile = ~/.gitignore
[apply]
	whitespace = nowarn
[format]
	pretty = %C(yellow)%h%Creset %s %C(red)(%an, %cr)%Creset
[push]
	default = simple
[merge "theirs"]
	driver = true
[merge "ours"]
	driver = true
[pull]
	rebase = true
[pager]
	branch = false
[init]
	defaultBranch = main
[merge]
	conflictstyle = diff3
